<Window x:Class="Clicky.UI.Overlay.CursorOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Clicky Overlay"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        IsHitTestVisible="False"
        Focusable="False">

    <!-- A single absolute-positioned canvas hosts every overlay visual. Elements
         are shown/hidden and repositioned from code-behind on the render loop. -->
    <Canvas x:Name="RootCanvas">

        <!-- Blue triangle cursor (idle / responding / flight). RenderTransform is
             set in code so the tip rotates to face its direction of travel. -->
        <Polygon x:Name="TriangleShape"
                 Points="10,0 20,28 0,28"
                 Fill="#3380FF"
                 Visibility="Collapsed"
                 RenderTransformOrigin="0.5,0.5">
            <Polygon.Effect>
                <DropShadowEffect x:Name="TriangleGlow" Color="#3380FF" BlurRadius="8" ShadowDepth="0" Opacity="0.9" />
            </Polygon.Effect>
            <Polygon.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="TriangleScale" ScaleX="1" ScaleY="1" />
                    <RotateTransform x:Name="TriangleRotation" Angle="-35" />
                </TransformGroup>
            </Polygon.RenderTransform>
        </Polygon>

        <!-- Listening waveform — bars sized by the live audio power level. -->
        <Canvas x:Name="WaveformCanvas" Visibility="Collapsed" Width="60" Height="40" />

        <!-- Processing spinner — a rotating arc. -->
        <Path x:Name="SpinnerShape"
              Visibility="Collapsed"
              Stroke="#3380FF"
              StrokeThickness="3"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
              Data="M 12,0 A 12,12 0 1 1 0,12"
              RenderTransformOrigin="0.5,0.5">
            <Path.RenderTransform>
                <RotateTransform x:Name="SpinnerRotation" Angle="0" />
            </Path.RenderTransform>
        </Path>

        <!-- Response / pointing speech bubble, shown next to the cursor. -->
        <Border x:Name="BubbleBorder"
                Visibility="Collapsed"
                Background="#171918"
                BorderBrush="#373B39"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12,8"
                MaxWidth="320">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="0" Opacity="0.5" />
            </Border.Effect>
            <TextBlock x:Name="BubbleText"
                       Foreground="#ECEEED"
                       FontSize="14"
                       TextWrapping="Wrap"
                       FontFamily="Segoe UI" />
        </Border>
    </Canvas>
</Window>
