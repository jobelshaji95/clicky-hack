{
  "Hotkey": {
    "// comment": "Push-to-talk modifiers. Defaults mirror the macOS ctrl+option (option == alt on Windows).",
    "RequireControl": true,
    "RequireAlt": true,
    "RequireShift": false,
    "RequireWindows": false
  },
  "VisionLlm": {
    "// comment": "Local llama.cpp server hosting a vision GGUF (Qwen2.5-VL recommended).",
