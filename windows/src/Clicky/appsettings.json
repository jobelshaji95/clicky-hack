    "ServerExecutableRelativePath": "tools\\llama-server.exe",
    "ModelRelativePath": "models\\qwen2.5-vl-7b-instruct-q4_k_m.gguf",
    "MultimodalProjectorRelativePath": "models\\qwen2.5-vl-7b-instruct-mmproj-f16.gguf",
    "Host": "127.0.0.1",
    "Port": 8080,
    "ModelName": "qwen2.5-vl",
    "MaxTokens": 1024,
    "ContextSize": 8192,
    "GpuLayers": 999
  },
  "Stt": {
    "WhisperModelRelativePath": "models\\ggml-base.en.bin",
    "Language": "en"
  },
  "Tts": {
